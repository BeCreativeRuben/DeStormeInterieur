# Resend (https://resend.com) — required for the contact form
# On Vercel: add both to Production (and Preview if needed), then redeploy.
RESEND_API_KEY=

# Verified sender in Resend, e.g. "Aanvragen <onboarding@resend.dev>" for testing
# or "DESTORME DESIGN <hello@yourdomain.com>" once your domain is verified
CONTACT_FROM_EMAIL=

# Where studio inquiries go (defaults to site email from lib/site.ts if unset)
# CONTACT_TO_EMAIL=

# Public site URL (logo in emails loads from {this}/brand-mark.png). On Vercel set to https://destormedesign.be
# NEXT_PUBLIC_SITE_URL=
